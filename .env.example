# Required: Anthropic API key for LLM analysis + email generation
ANTHROPIC_API_KEY=sk-ant-...

# Optional: Google PageSpeed Insights API key (free, get from Google Cloud Console)
# Without this, PageSpeed analysis will be skipped
PAGESPEED_API_KEY=

# Optional: Google Custom Search API (for 'prospect' mode)
# Free tier: 100 queries/day
# Get keys at: https://developers.google.com/custom-search/v1/introduction
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# LLM model to use (default: claude-sonnet-4-6)
LLM_MODEL=claude-sonnet-4-6

# Zoho Mail SMTP (for sending emails)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_EMAIL=tomasmaxim@emtdstudio.com
# Use an app-specific password if 2FA is enabled:
# Zoho → Settings → Security → App Passwords → Generate
SMTP_PASSWORD=

# Delay between sending emails (seconds) — avoid spam flags
SEND_DELAY_SECONDS=30

# Rate limiting
PAGESPEED_DELAY_SECONDS=2
SCRAPE_DELAY_SECONDS=1

# Output directory
OUTPUT_DIR=output
